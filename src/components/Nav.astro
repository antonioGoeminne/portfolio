  </div>

  <!-- Mobile hamburger -->
  <button
    id="nav-toggle"
    class="sm:hidden flex flex-col justify-center items-center w-8 h-8 border border-black"
    aria-label="Toggle menu"
    aria-expanded="false"
  >
    <span class="nav-bar block w-4 h-px bg-black transition-transform duration-200"></span>
    <span class="nav-bar block w-4 h-px bg-black mt-1.5 transition-transform duration-200"></span>
  </button>
</nav>

<!-- Mobile overlay menu -->
<div
  id="nav-menu"
  class="fixed inset-0 bg-white z-40 flex-col items-center justify-center gap-4 sm:hidden"
  style="display: none;"
>
  <a href="/#work" class="nav-link w-56 text-center px-6 py-3 text-sm font-bold border border-black hover:bg-black hover:text-white transition-colors">WORK</a>
  <a href="/#about" class="nav-link w-56 text-center px-6 py-3 text-sm font-bold border border-black hover:bg-black hover:text-white transition-colors">ABOUT</a>
  <a href="/#contact" class="nav-link w-56 text-center px-6 py-3 text-sm font-bold border border-black hover:bg-black hover:text-white transition-colors">CONTACT</a>
  <a href="#lab" class="nav-link w-56 text-center px-6 py-3 text-sm font-bold border border-black hover:bg-black hover:text-white transition-colors">LAB</a>
  <a href="/resume.pdf" target="_blank" rel="noopener noreferrer" class="resume-btn nav-link w-56 text-center px-6 py-3 text-sm font-bold bg-black text-white border border-black transition-colors">RESUME</a>
</div>

<script is:inline>
  function initNav() {
    const toggle = document.getElementById('nav-toggle');
    const menu = document.getElementById('nav-menu');
    if (!toggle || !menu) return;

    function openMenu() {
      menu.style.display = 'flex';
      toggle.setAttribute('aria-expanded', 'true');
      toggle.classList.add('nav-open');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      menu.style.display = 'none';
      toggle.setAttribute('aria-expanded', 'false');
      toggle.classList.remove('nav-open');
      document.body.style.overflow = '';
    }

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      isOpen ? closeMenu() : openMenu();
    });

    menu.querySelectorAll('.nav-link').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });
  }

  // astro:page-load fires on first load AND after every View Transition
  // Using it as the single entry point avoids duplicate listeners
  document.addEventListener('astro:page-load', initNav);
</script>

<style>
  /* Hamburger to X animation */
  .nav-open .nav-bar:first-child {
    transform: translateY(3.5px) rotate(45deg);
  }
  .nav-open .nav-bar:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
  }

  /* Resume button rainbow hover */
  .resume-btn {
    background-size: 100% 100%;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
  }

  .resume-btn:hover {
    background-image: linear-gradient(
      90deg,
      #ff0000, #ff8800, #ffff00, #00ff00,
      #00ffff, #0066ff, #8800ff, #ff0088, #ff0000
    );
    background-size: 300% 100%;
    animation: resume-rainbow 4s linear infinite;
    color: white;
    border-color: transparent;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
  }

  @keyframes resume-rainbow {
    0% { background-position: 0% 50%; }
    100% { background-position: 300% 50%; }
  }
</style>
