---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort(
	(a, b) => a.data.index - b.data.index,
);

const experiments = (await getCollection("experiments")).sort(
	(a, b) => a.data.index - b.data.index,
);
---

<BaseLayout title="TONI.DEV">

  <!-- HERO -->
  <section class="px-4 sm:px-6 py-10 sm:py-16">
    <div class="border border-black p-5 sm:p-8 md:p-12 relative">
      <div class="flex items-center gap-2 mb-6">
        <span class="w-2.5 h-2.5 bg-black inline-block" data-boot data-boot-step="0"></span>
        <span class="text-[10px] tracking-widest uppercase" data-boot data-boot-step="0">
          <span data-typewriter>SYSTEM_INIT_01</span><span class="cursor-block" data-boot-cursor></span>
        </span>
      </div>
      <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tight leading-none mb-6" data-boot data-boot-step="1">
        TONI.DEV
      </h1>
      <!-- MARQUEE TICKER -->
      <div class="marquee-container" data-boot data-boot-step="2">
        <div class="marquee-track text-base md:text-lg font-bold tracking-wide">
          <span class="pr-12">SOFTWARE ENGINEER. FULLSTACK DEV. PRODUCT ENGINEER.&nbsp;&nbsp;&bull;&nbsp;&nbsp;</span>
          <span class="pr-12">SOFTWARE ENGINEER. FULLSTACK DEV. PRODUCT ENGINEER.&nbsp;&nbsp;&bull;&nbsp;&nbsp;</span>
          <span class="pr-12">SOFTWARE ENGINEER. FULLSTACK DEV. PRODUCT ENGINEER.&nbsp;&nbsp;&bull;&nbsp;&nbsp;</span>
          <span class="pr-12">SOFTWARE ENGINEER. FULLSTACK DEV. PRODUCT ENGINEER..&nbsp;&nbsp;&bull;&nbsp;&nbsp;</span>
        </div>
      </div>
      <div class="mt-10 flex flex-col items-end text-[10px] tracking-wider leading-relaxed">
        <span data-boot data-boot-step="3">STATUS: WORKING_ON_PLANT.</span>
        <span data-boot data-boot-step="4">LOCATION: BUENOS_AIRES, AR</span>
      </div>
    </div>
  </section>

  <!-- PROJECT INDEX -->
  <section id="work" class="px-4 sm:px-6 py-10 sm:py-16">
    <div class="flex items-baseline justify-between mb-8">
      <h2 class="text-lg md:text-xl font-bold">WORK_INDEX</h2>
      <span class="text-xs">[{projects.length}_SELECTED_WORKS]</span>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6">
      {projects.map((project, i) => (
        <a href={`/projects/${project.id}`} class="group border border-black block " data-reveal style={`--reveal-i:${i}`}>
            <div class="aspect-4/3 w-full overflow-hidden">
            {!!project?.data?.image && <Image width={300} height={300} layout='full-width' src={project?.data?.image} alt={project?.data?.title} class="w-full h-full object-cover object-left brightness-[0.4] group-hover:brightness-100 group-hover:scale-105 transition-all duration-500 ease-out" />}
            </div>
          <div class="p-4 flex items-end justify-between">
            <div>
              <span class="text-[10px] tracking-wider text-neutral-500  duration-75">{String(project.data.index).padStart(2, '0')} / {project.data.category}</span>
              <h3 class="text-sm font-bold mt-1" transition:name={`title-${project.id}`}>{project.data.title}</h3>
            </div>
            <span class="text-lg">&nearr;</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ABOUT ME -->
  <section id="about" class="px-4 sm:px-6 py-10 sm:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-0 border border-black" data-reveal>

      <div class="bg-black text-white p-6 sm:p-8 flex flex-col justify-between min-h-[240px] sm:min-h-[320px]">
        <div>
          <h2 class="text-2xl md:text-3xl font-extrabold leading-tight">ABOUT<br />ME</h2>
        </div>
        <span class="text-[10px] tracking-wider text-neutral-400">EST. 2022</span>
      </div>

      <div class="p-6 sm:p-8">
        <div class="flex justify-end mb-4">
          <span class="text-[10px] tracking-wider border border-black px-2 py-0.5">BIO_DATA</span>
        </div>
        <p class="text-xs leading-relaxed font-medium mb-8 max-w-md uppercase">
   I've spent four years shipping full-stack products with React and Node. Somewhere along the way I got more obsessed with the question before the code: what should we build, and why.

I use whatever it takes — including AI agents — to get closer to the real problem: why products fail to retain users, where teams build the wrong thing, and how to close the gap between what gets shipped and what actually matters.
        </p>
        <hr class="border-black mb-6" />
        <div class="grid grid-cols-2 gap-6">
          <div>
            <span class="text-[10px] tracking-wider text-neutral-500 block mb-3">CORE_STACK</span>
            <ul class="text-xs space-y-1 font-medium">
              <li>REACT</li>
              <li>TYPESCRIPT</li>
              <li>NEXT_JS</li>
              <li>NODE_JS</li>
              <li>MONGO_DB</li>
              <li>FIREBASE</li>
              <li>REACT_QUERY</li>
              <li>REACT_NATIVE</li>
            </ul>
          </div>
          <div>
            <span class="text-[10px] tracking-wider text-neutral-500 block mb-3">CORE_FOCUS</span>
            <ul class="text-xs space-y-1 font-medium">
              <li>FEATURES_ARCHITECTURE</li>
              <li>SYSTEM_DESIGN</li>
              <li>INTERACTION_LOGIC</li>
              <li>PRODUCT_STRATEGY</li>
            </ul>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- EXPERIENCE LOG -->
  <section id="experience" class="px-4 sm:px-6 py-10 sm:py-16">
    <div class="flex items-baseline justify-between mb-12">
      <h2 class="text-lg md:text-xl font-bold">EXPERIENCE_LOG</h2>
      <span class="text-xs">[TIMELINE_ACTIVE]</span>
    </div>

    <div class="relative">
      <!-- Timeline line -->
      <div id="timeline-line" class="absolute left-[7px] top-0 w-px bg-black"></div>

      <!-- Entry 1 -->
      <div class="flex flex-col md:flex-row gap-6 md:gap-10 mb-12 relative" data-reveal style="--reveal-i:0">
        <div class="flex items-start gap-3 md:w-[240px] shrink-0">
          <div class="w-3.5 h-3.5 bg-black rounded-full mt-1 relative z-10"></div>
          <div>
            <span class="text-xs font-bold block">JAN 2023 - PRESENT</span>
            <span class="text-[10px] tracking-wider text-neutral-500">2 YRS 3 MOS</span>
          </div>
        </div>
        <div class="border border-black p-4 sm:p-6 flex-1 ml-6 md:ml-0">
          <div class="flex items-start justify-between mb-2">
            <div>
              <h3 class="text-sm sm:text-base md:text-lg font-extrabold">FULL_STACK_MERN_DEVELOPER</h3>
              <span class="text-xs font-bold block mt-1">PLANT</span>
            </div>
            <span class="border border-black p-1.5 shrink-0">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V8l8 5 8-5v10zm-8-7L4 6h16l-8 5z"/></svg>
            </span>
          </div>
          <p class="text-xs leading-relaxed mt-4 uppercase">
            OPTIMIZED ORGANIC SEO WITH NEXT.JS UTILIZING DESCRIPTIVE META TAGS FOR ENHANCED CRAWLER INDEXING. IMPLEMENTED COMPREHENSIVE SSR STRATEGY TO STABILIZE SERVER-SIDE PERFORMANCE AND RELIABILITY.
          </p>
        </div>
      </div>

      <!-- Entry 2 -->
      <div class="flex flex-col md:flex-row gap-6 md:gap-10 mb-12 relative" data-reveal style="--reveal-i:1">
        <div class="flex items-start gap-3 md:w-[240px] shrink-0">
          <div class="w-3.5 h-3.5 bg-black rounded-full mt-1 relative z-10"></div>
          <div>
            <span class="text-xs font-bold block">JAN 2023 - DEC 2024</span>
            <span class="text-[10px] tracking-wider text-neutral-500">2 YRS</span>
          </div>
        </div>
        <div class="border border-black p-4 sm:p-6 flex-1 ml-6 md:ml-0">
          <div class="flex items-start justify-between mb-2">
            <div>
              <h3 class="text-sm sm:text-base md:text-lg font-extrabold">REACT_&_REACT_NATIVE_DEVELOPER</h3>
              <span class="text-xs font-bold block mt-1">PLANT</span>
            </div>
            <span class="border border-black p-1.5 shrink-0">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17 1.01L7 1c-1.1 0-2 .9-2 2v18c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V3c0-1.1-.9-1.99-2-1.99zM17 19H7V5h10v14z"/></svg>
            </span>
          </div>
          <p class="text-xs leading-relaxed mt-4 uppercase">
            ARCHITECTED MOBILE ECOSYSTEM VIA EXPO, SCALING TO 1K+ MONTHLY ACTIVE USERS. INTEGRATED PUSH NOTIFICATION SYSTEMS, OTA UPDATES, AND SECURE AUTHENTICATION PROTOCOLS FOR SEAMLESS DEPLOYMENT.
          </p>
        </div>
      </div>

      <!-- Entry 3 -->
      <div class="flex flex-col md:flex-row gap-6 md:gap-10 relative" data-reveal style="--reveal-i:2">
        <div class="flex items-start gap-3 md:w-[240px] shrink-0">
          <div class="w-3.5 h-3.5 bg-black rounded-full mt-1 relative z-10"></div>
          <div>
            <span class="text-xs font-bold block">JAN 2022 - DEC 2022</span>
            <span class="text-[10px] tracking-wider text-neutral-500">1 YR</span>
          </div>
        </div>
        <div class="border border-black p-4 sm:p-6 flex-1 ml-6 md:ml-0">
          <div class="flex items-start justify-between mb-2">
            <div>
              <h3 class="text-sm sm:text-base md:text-lg font-extrabold">REACT_DEVELOPER</h3>
              <span class="text-xs font-bold block mt-1">VIVET</span>
            </div>
            <span class="border border-black p-1.5 shrink-0">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            </span>
          </div>
          <p class="text-xs leading-relaxed mt-4 uppercase">
            DEVELOPED CORE FRONTEND ARCHITECTURE USING REACT.JS AND FIREBASE. FOCUSED ON STATE MANAGEMENT OPTIMIZATION AND CROSS-PLATFORM CONSISTENCY FOR REMOTE-FIRST DELIVERY.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- LAB EXPERIMENTS -->
  <section id="lab" class="px-4 sm:px-6 py-10 sm:py-16">
    <div class="flex items-baseline justify-between mb-8">
      <h2 class="text-lg md:text-xl font-bold">LAB_EXPERIMENTS</h2>
      <span class="text-xs">[RAW_REPOS_&_SKETCHES]</span>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 sm:gap-6">
      {experiments.map((exp, i) => (
        <div class="border border-black p-5 hover-invert" data-reveal style={`--reveal-i:${i}`}>
          <div class="flex items-center justify-between mb-4">
            <span class="text-[10px] tracking-widest bg-black text-white px-2 py-0.5 font-bold">[EXP_{String(exp.data.index).padStart(2, '0')}]</span>
            <span class="text-[10px] tracking-widest text-neutral-500">STATUS: {exp.data.status}</span>
          </div>
          <h3 class="text-sm font-extrabold mb-2">{exp.data.title}</h3>
          <p class="text-xs leading-relaxed uppercase text-neutral-600 mb-4">
            {exp.data.description}
          </p>
          <hr class="border-black mb-3" />
          <div class="flex items-center justify-between">
            <div class="flex gap-4 text-[10px] tracking-wider font-bold">
              {exp.data.stack.map((tech) => (
                <span>{tech}</span>
              ))}
            </div>
            <div class="flex gap-3">
              {exp.data.github && (
                <a href={exp.data.github} target="_blank" rel="noopener noreferrer" title="GitHub">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                </a>
              )}
              {exp.data.website && (
                <a href={exp.data.website} target="_blank" rel="noopener noreferrer" title="Website">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CONTACT / INITIATE PROJECT -->
  <section id="contact" class="px-4 sm:px-6 py-12 sm:py-20 text-center" data-reveal>
    <h2 class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-extrabold tracking-tight mb-8 sm:mb-12">
      INITIATE_PROJECT
    </h2>
    <div class="flex flex-col sm:flex-row flex-wrap justify-center gap-3 sm:gap-4">
      <a href="mailto:antonionicolasgoeminne@gmail.com" class="glitch-hover border border-black px-6 py-3 hover-invert" data-text="SEND_MAIL">
        <span class="text-[10px] tracking-wider text-neutral-500 block mb-1">EMAIL_LINK</span>
        <span class="text-sm font-bold">SEND_MAIL</span>
      </a>
    </div>
  </section>

</BaseLayout>

<script>
  // ═══════════════════════════════════════════
  // BOOT SEQUENCE
  // ═══════════════════════════════════════════
  function runBootSequence() {
    const steps = document.querySelectorAll<HTMLElement>('[data-boot]');
    const typewriterEl = document.querySelector('[data-typewriter]');
    const cursorEl = document.querySelector('[data-boot-cursor]');

    if (!typewriterEl || !cursorEl) return;

    const fullText = typewriterEl.textContent || '';
    typewriterEl.textContent = '';

    // Group by step number
    const groups = new Map<number, HTMLElement[]>();
    steps.forEach((el) => {
      const step = parseInt(el.dataset.bootStep || '0');
      if (!groups.has(step)) groups.set(step, []);
      groups.get(step)!.push(el);
    });

    const sortedSteps = [...groups.keys()].sort((a, b) => a - b);
    let delay = 0;

    // Step 0: typewriter first
    sortedSteps.forEach((stepNum) => {
      const els = groups.get(stepNum)!;

      if (stepNum === 0) {
        // Show elements immediately (they contain the typewriter)
        els.forEach((el) => {
          setTimeout(() => {
            el.style.opacity = '1';
          }, delay);
        });

        // Typewriter effect
        const charDelay = 40;
        for (let i = 0; i < fullText.length; i++) {
          setTimeout(() => {
            typewriterEl.textContent = fullText.slice(0, i + 1);
          }, delay + i * charDelay);
        }
        delay += fullText.length * charDelay + 200;

        // Hide cursor after typewriter completes
        setTimeout(() => {
          (cursorEl as HTMLElement).style.display = 'none';
        }, delay);
      } else {
        // Reveal with boot-in animation
        els.forEach((el) => {
          setTimeout(() => {
            el.classList.add('boot-reveal');
          }, delay);
        });
        delay += 150;
      }
    });
  }

  // Run on initial load and View Transition navigations
  function initBoot() {
    // Boot sequence only on home page, only on first visit
    if (window.location.pathname === '/' && !document.documentElement.dataset.booted) {
      document.documentElement.dataset.booted = 'true';
      runBootSequence();
    } else {
      // If returning to home via back nav, just show everything
      document.querySelectorAll<HTMLElement>('[data-boot]').forEach((el) => {
        el.style.opacity = '1';
        el.classList.add('boot-reveal');
      });
    }
  }

  // DOMContentLoaded for first load
  document.addEventListener('DOMContentLoaded', initBoot);
  // astro:page-load fires on every View Transition navigation
  document.addEventListener('astro:page-load', initBoot);

  // ═══════════════════════════════════════════
  // TIMELINE LINE HEIGHT
  // ═══════════════════════════════════════════
  function initTimelineLine() {
    const line = document.getElementById('timeline-line');
    if (!line) return;
    const container = line.parentElement!;
    const dots = container.querySelectorAll<HTMLElement>('.rounded-full');
    if (dots.length === 0) return;
    const lastDot = dots[dots.length - 1];
    const containerRect = container.getBoundingClientRect();
    const dotRect = lastDot.getBoundingClientRect();
    const height = dotRect.top - containerRect.top + dotRect.height / 2;
    line.style.height = `${height}px`;
  }

  document.addEventListener('DOMContentLoaded', initTimelineLine);
  document.addEventListener('astro:page-load', initTimelineLine);
  window.addEventListener('resize', initTimelineLine);
</script>
