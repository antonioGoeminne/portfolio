---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <title>TONI.DEV</title>
  </head>
  <body class="bg-white text-black font-mono antialiased">

    <!-- NAV -->
    <nav class="flex items-center justify-between px-6 py-4 border-b border-black">
      <span class="text-sm font-bold tracking-tight">TONI.DEV</span>
      <div class="flex items-center gap-2">
        <a href="#work" class="px-3 py-1 text-xs border border-black hover:bg-black hover:text-white transition-colors">WORK</a>
        <a href="#about" class="px-3 py-1 text-xs border border-black hover:bg-black hover:text-white transition-colors">ABOUT</a>
        <a href="#contact" class="px-3 py-1 text-xs border border-black hover:bg-black hover:text-white transition-colors">CONTACT</a>
        <a href="#lab" class="px-3 py-1 text-xs border border-black hover:bg-black hover:text-white transition-colors">LAB</a>
        <a href="#resume" class="px-3 py-1 text-xs bg-black text-white border border-black hover:bg-white hover:text-black transition-colors">RESUME</a>
      </div>
    </nav>

    <!-- HERO -->
    <section class="px-6 py-16">
      <div class="border border-black p-8 md:p-12 relative">
        <div class="flex items-center gap-2 mb-6">
          <span class="w-2.5 h-2.5 bg-black inline-block"></span>
          <span class="text-[10px] tracking-widest uppercase">SYSTEM_INIT_01</span>
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tight leading-none mb-6">
          TONI.DEV
        </h1>
        <p class="text-base md:text-lg font-bold tracking-wide">
          DESIGNER. DEVELOPER.<br />
          DIGITAL ARCHITECT.
        </p>
        <div class="mt-10 flex flex-col items-end text-[10px] tracking-wider leading-relaxed">
          <span>STATUS: AVAILABLE_FOR_PROJECTS</span>
          <span>LOCATION: BUENOS_AIRES, AR</span>
        </div>
      </div>
    </section>

    <!-- PROJECT INDEX -->
    <section id="work" class="px-6 py-16">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="text-lg md:text-xl font-bold">PROJECT_INDEX</h2>
        <span class="text-xs">[4_SELECTED_WORKS]</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <a href="#" class="group border border-black block">
          <div class="aspect-[4/3] bg-neutral-900 overflow-hidden">
            <div class="w-full h-full bg-gradient-to-br from-neutral-800 to-neutral-950 group-hover:scale-105 transition-transform duration-300"></div>
          </div>
          <div class="p-4 flex items-end justify-between">
            <div>
              <span class="text-[10px] tracking-wider text-neutral-500">01 / BRANDING</span>
              <h3 class="text-sm font-bold mt-1">KINETIC_MONOLITH</h3>
            </div>
            <span class="text-lg group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform">&nearr;</span>
          </div>
        </a>

        <a href="#" class="group border border-black block">
          <div class="aspect-[4/3] bg-neutral-900 overflow-hidden">
            <div class="w-full h-full bg-gradient-to-br from-neutral-700 to-neutral-950 group-hover:scale-105 transition-transform duration-300"></div>
          </div>
          <div class="p-4 flex items-end justify-between">
            <div>
              <span class="text-[10px] tracking-wider text-neutral-500">02 / INTERFACE</span>
              <h3 class="text-sm font-bold mt-1">NEURAL_INTERFACE_V2</h3>
            </div>
            <span class="text-lg group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform">&nearr;</span>
          </div>
        </a>

        <a href="#" class="group border border-black block">
          <div class="aspect-[4/3] bg-neutral-900 overflow-hidden">
            <div class="w-full h-full bg-gradient-to-br from-neutral-800 to-neutral-900 group-hover:scale-105 transition-transform duration-300"></div>
          </div>
          <div class="p-4 flex items-end justify-between">
            <div>
              <span class="text-[10px] tracking-wider text-neutral-500">03 / E-COMMERCE</span>
              <h3 class="text-sm font-bold mt-1">STRUCTURE_RETAIL</h3>
            </div>
            <span class="text-lg group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform">&nearr;</span>
          </div>
        </a>

        <a href="#" class="group border border-black block">
          <div class="aspect-[4/3] bg-neutral-900 overflow-hidden">
            <div class="w-full h-full bg-gradient-to-br from-neutral-600 to-neutral-950 group-hover:scale-105 transition-transform duration-300"></div>
          </div>
          <div class="p-4 flex items-end justify-between">
            <div>
              <span class="text-[10px] tracking-wider text-neutral-500">04 / WEB_APP</span>
              <h3 class="text-sm font-bold mt-1">OS_FOUNDATION</h3>
            </div>
            <span class="text-lg group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform">&nearr;</span>
          </div>
        </a>

      </div>
    </section>

    <!-- ABOUT / THE MONOLITH -->
    <section id="about" class="px-6 py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0 border border-black">

        <div class="bg-black text-white p-8 flex flex-col justify-between min-h-[320px]">
          <div>
            <h2 class="text-2xl md:text-3xl font-extrabold leading-tight">THE<br />MONOLITH</h2>
          </div>
          <span class="text-[10px] tracking-wider text-neutral-400">EST. 2018</span>
        </div>

        <div class="p-8">
          <div class="flex justify-end mb-4">
            <span class="text-[10px] tracking-wider border border-black px-2 py-0.5">BIO_DATA</span>
          </div>
          <p class="text-xs leading-relaxed font-medium mb-8 max-w-md uppercase">
            I build digital systems that prioritize structural integrity over visual noise. My philosophy is rooted in the belief that software should feel as permanent and deliberate as concrete.
          </p>
          <hr class="border-black mb-6" />
          <div class="grid grid-cols-2 gap-6">
            <div>
              <span class="text-[10px] tracking-wider text-neutral-500 block mb-3">CORE_STACK</span>
              <ul class="text-xs space-y-1 font-medium">
                <li>TYPESCRIPT</li>
                <li>RUST</li>
                <li>TAILWIND_CSS</li>
                <li>PYTHON</li>
              </ul>
            </div>
            <div>
              <span class="text-[10px] tracking-wider text-neutral-500 block mb-3">CORE_FOCUS</span>
              <ul class="text-xs space-y-1 font-medium">
                <li>UI_ARCHITECTURE</li>
                <li>SYSTEM_DESIGN</li>
                <li>BRAND_SCHEMATICS</li>
                <li>INTERACTION_LOGIC</li>
              </ul>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- CONTACT / INITIATE PROJECT -->
    <section id="contact" class="px-6 py-20 text-center">
      <h2 class="text-4xl md:text-6xl lg:text-7xl font-extrabold tracking-tight mb-12">
        INITIATE_PROJECT
      </h2>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="mailto:hello@toni.dev" class="border border-black px-6 py-3 hover:bg-black hover:text-white transition-colors">
          <span class="text-[10px] tracking-wider text-neutral-500 block mb-1">EMAIL_LINK</span>
          <span class="text-sm font-bold">SEND_MAIL</span>
        </a>
        <a href="#" class="border border-black px-6 py-3 hover:bg-black hover:text-white transition-colors">
          <span class="text-[10px] tracking-wider text-neutral-500 block mb-1">CALENDAR_SYNC</span>
          <span class="text-sm font-bold">BOOK_CALL</span>
        </a>
        <a href="#" class="border border-black px-6 py-3 hover:bg-black hover:text-white transition-colors">
          <span class="text-[10px] tracking-wider text-neutral-500 block mb-1">SOCIAL_AUTH</span>
          <span class="text-sm font-bold">LINKEDIN</span>
        </a>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="px-6 py-4 border-t border-black flex flex-col md:flex-row items-center justify-between gap-4 text-[10px] tracking-wider">
      <span class="font-bold text-xs">TONI.DEV</span>
      <div class="flex items-center gap-6">
        <a href="#" class="hover:underline">GITHUB</a>
        <a href="#" class="hover:underline">LINKEDIN</a>
        <a href="#" class="hover:underline">ARE.NA</a>
        <a href="#" class="hover:underline">EMAIL</a>
      </div>
      <span class="text-neutral-500">&copy;2024 TONI.DEV. ALL RIGHTS RESERVED.</span>
    </footer>

  </body>
</html>
