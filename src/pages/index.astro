---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.index - b.data.index);
---

<BaseLayout title="TONI.DEV">

  <!-- HERO -->
  <section class="px-6 py-16">
    <div class="border border-black p-8 md:p-12 relative">
      <div class="flex items-center gap-2 mb-6">
        <span class="w-2.5 h-2.5 bg-black inline-block"></span>
        <span class="text-[10px] tracking-widest uppercase">SYSTEM_INIT_01</span>
      </div>
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tight leading-none mb-6">
        TONI.DEV
      </h1>
      <p class="text-base md:text-lg font-bold tracking-wide">
        DESIGNER. DEVELOPER.<br />
        DIGITAL ARCHITECT.
      </p>
      <div class="mt-10 flex flex-col items-end text-[10px] tracking-wider leading-relaxed">
        <span>STATUS: AVAILABLE_FOR_PROJECTS</span>
        <span>LOCATION: BUENOS_AIRES, AR</span>
      </div>
    </div>
  </section>

  <!-- PROJECT INDEX -->
  <section id="work" class="px-6 py-16">
    <div class="flex items-baseline justify-between mb-8">
      <h2 class="text-lg md:text-xl font-bold">PROJECT_INDEX</h2>
      <span class="text-xs">[{projects.length}_SELECTED_WORKS]</span>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <a href={`/projects/${project.id}`} class="group border border-black block">
          <div class="aspect-[4/3] bg-neutral-900 overflow-hidden">
            <div class="w-full h-full bg-gradient-to-br from-neutral-800 to-neutral-950 group-hover:scale-105 transition-transform duration-300"></div>
          </div>
          <div class="p-4 flex items-end justify-between">
            <div>
              <span class="text-[10px] tracking-wider text-neutral-500">{String(project.data.index).padStart(2, '0')} / {project.data.category}</span>
              <h3 class="text-sm font-bold mt-1">{project.data.title}</h3>
            </div>
            <span class="text-lg group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform">&nearr;</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ABOUT / THE MONOLITH -->
  <section id="about" class="px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-0 border border-black">

      <div class="bg-black text-white p-8 flex flex-col justify-between min-h-[320px]">
        <div>
          <h2 class="text-2xl md:text-3xl font-extrabold leading-tight">THE<br />MONOLITH</h2>
        </div>
        <span class="text-[10px] tracking-wider text-neutral-400">EST. 2018</span>
      </div>

      <div class="p-8">
        <div class="flex justify-end mb-4">
          <span class="text-[10px] tracking-wider border border-black px-2 py-0.5">BIO_DATA</span>
        </div>
        <p class="text-xs leading-relaxed font-medium mb-8 max-w-md uppercase">
          I build digital systems that prioritize structural integrity over visual noise. My philosophy is rooted in the belief that software should feel as permanent and deliberate as concrete.
        </p>
        <hr class="border-black mb-6" />
        <div class="grid grid-cols-2 gap-6">
          <div>
            <span class="text-[10px] tracking-wider text-neutral-500 block mb-3">CORE_STACK</span>
            <ul class="text-xs space-y-1 font-medium">
              <li>TYPESCRIPT</li>
              <li>RUST</li>
              <li>TAILWIND_CSS</li>
              <li>PYTHON</li>
            </ul>
          </div>
          <div>
            <span class="text-[10px] tracking-wider text-neutral-500 block mb-3">CORE_FOCUS</span>
            <ul class="text-xs space-y-1 font-medium">
              <li>UI_ARCHITECTURE</li>
              <li>SYSTEM_DESIGN</li>
              <li>BRAND_SCHEMATICS</li>
              <li>INTERACTION_LOGIC</li>
            </ul>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- EXPERIENCE LOG -->
  <section id="experience" class="px-6 py-16">
    <div class="flex items-baseline justify-between mb-12">
      <h2 class="text-lg md:text-xl font-bold">EXPERIENCE_LOG</h2>
      <span class="text-xs">[TIMELINE_ACTIVE]</span>
    </div>

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-[7px] md:left-[120px] top-0 bottom-0 w-px bg-black"></div>

      <!-- Entry 1 -->
      <div class="flex flex-col md:flex-row gap-6 md:gap-10 mb-12 relative">
        <div class="flex items-start gap-3 md:w-[240px] shrink-0">
          <div class="w-3.5 h-3.5 bg-black rounded-full mt-1 relative z-10"></div>
          <div>
            <span class="text-xs font-bold block">JAN 2023 - PRESENT</span>
            <span class="text-[10px] tracking-wider text-neutral-500">2 YRS 3 MOS</span>
          </div>
        </div>
        <div class="border border-black p-6 flex-1 ml-6 md:ml-0">
          <div class="flex items-start justify-between mb-2">
            <div>
              <h3 class="text-base md:text-lg font-extrabold">FULL_STACK_MERN_DEVELOPER</h3>
              <span class="text-xs font-bold block mt-1">PLANT</span>
            </div>
            <span class="border border-black p-1.5 shrink-0">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V8l8 5 8-5v10zm-8-7L4 6h16l-8 5z"/></svg>
            </span>
          </div>
          <p class="text-xs leading-relaxed mt-4 uppercase">
            OPTIMIZED ORGANIC SEO WITH NEXT.JS UTILIZING DESCRIPTIVE META TAGS FOR ENHANCED CRAWLER INDEXING. IMPLEMENTED COMPREHENSIVE SSR STRATEGY TO STABILIZE SERVER-SIDE PERFORMANCE AND RELIABILITY.
          </p>
        </div>
      </div>

      <!-- Entry 2 -->
      <div class="flex flex-col md:flex-row gap-6 md:gap-10 mb-12 relative">
        <div class="flex items-start gap-3 md:w-[240px] shrink-0">
          <div class="w-3.5 h-3.5 bg-black rounded-full mt-1 relative z-10"></div>
          <div>
            <span class="text-xs font-bold block">JAN 2023 - DEC 2024</span>
            <span class="text-[10px] tracking-wider text-neutral-500">2 YRS</span>
          </div>
        </div>
        <div class="border border-black p-6 flex-1 ml-6 md:ml-0">
          <div class="flex items-start justify-between mb-2">
            <div>
              <h3 class="text-base md:text-lg font-extrabold">REACT_&_REACT_NATIVE_DEVELOPER</h3>
              <span class="text-xs font-bold block mt-1">PLANT</span>
            </div>
            <span class="border border-black p-1.5 shrink-0">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17 1.01L7 1c-1.1 0-2 .9-2 2v18c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V3c0-1.1-.9-1.99-2-1.99zM17 19H7V5h10v14z"/></svg>
            </span>
          </div>
          <p class="text-xs leading-relaxed mt-4 uppercase">
            ARCHITECTED MOBILE ECOSYSTEM VIA EXPO, SCALING TO 1K+ MONTHLY ACTIVE USERS. INTEGRATED PUSH NOTIFICATION SYSTEMS, OTA UPDATES, AND SECURE AUTHENTICATION PROTOCOLS FOR SEAMLESS DEPLOYMENT.
          </p>
        </div>
      </div>

      <!-- Entry 3 -->
      <div class="flex flex-col md:flex-row gap-6 md:gap-10 relative">
        <div class="flex items-start gap-3 md:w-[240px] shrink-0">
          <div class="w-3.5 h-3.5 bg-black rounded-full mt-1 relative z-10"></div>
          <div>
            <span class="text-xs font-bold block">JAN 2022 - DEC 2022</span>
            <span class="text-[10px] tracking-wider text-neutral-500">1 YR</span>
          </div>
        </div>
        <div class="border border-black p-6 flex-1 ml-6 md:ml-0">
          <div class="flex items-start justify-between mb-2">
            <div>
              <h3 class="text-base md:text-lg font-extrabold">REACT_DEVELOPER</h3>
              <span class="text-xs font-bold block mt-1">VIVET</span>
            </div>
            <span class="border border-black p-1.5 shrink-0">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            </span>
          </div>
          <p class="text-xs leading-relaxed mt-4 uppercase">
            DEVELOPED CORE FRONTEND ARCHITECTURE USING REACT.JS AND FIREBASE. FOCUSED ON STATE MANAGEMENT OPTIMIZATION AND CROSS-PLATFORM CONSISTENCY FOR REMOTE-FIRST DELIVERY.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- LAB EXPERIMENTS -->
  <section id="lab" class="px-6 py-16">
    <div class="flex items-baseline justify-between mb-8">
      <h2 class="text-lg md:text-xl font-bold">LAB_EXPERIMENTS</h2>
      <span class="text-xs">[RAW_REPOS_&_SKETCHES]</span>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <div class="border border-black p-5">
        <div class="flex items-center justify-between mb-4">
          <span class="text-[10px] tracking-widest bg-black text-white px-2 py-0.5 font-bold">[EXP_01]</span>
          <span class="text-[10px] tracking-widest text-neutral-500">STATUS: ALPHA</span>
        </div>
        <h3 class="text-sm font-extrabold mb-2">NEURAL_GLITCH_SHADERS</h3>
        <p class="text-xs leading-relaxed uppercase text-neutral-600 mb-4">
          REAL-TIME WEBGL DISTORTIONS USING FEEDBACK LOOPS.
        </p>
        <hr class="border-black mb-3" />
        <div class="flex gap-4 text-[10px] tracking-wider font-bold">
          <span>RUST</span>
          <span>WGPU</span>
          <span>GLSL</span>
        </div>
      </div>

      <div class="border border-black p-5">
        <div class="flex items-center justify-between mb-4">
          <span class="text-[10px] tracking-widest bg-black text-white px-2 py-0.5 font-bold">[EXP_02]</span>
          <span class="text-[10px] tracking-widest text-neutral-500">STATUS: STABLE</span>
        </div>
        <h3 class="text-sm font-extrabold mb-2">DATABASE_SCHEMA_VIZ</h3>
        <p class="text-xs leading-relaxed uppercase text-neutral-600 mb-4">
          AUTO-GENERATING 3D RELATIONAL MAPS FROM SQL.
        </p>
        <hr class="border-black mb-3" />
        <div class="flex gap-4 text-[10px] tracking-wider font-bold">
          <span>PYTHON</span>
          <span>THREE.JS</span>
        </div>
      </div>

      <div class="border border-black p-5">
        <div class="flex items-center justify-between mb-4">
          <span class="text-[10px] tracking-widest bg-black text-white px-2 py-0.5 font-bold">[EXP_03]</span>
          <span class="text-[10px] tracking-widest text-neutral-500">STATUS: RECURSIVE</span>
        </div>
        <h3 class="text-sm font-extrabold mb-2">PROCEDURAL_VOXELS</h3>
        <p class="text-xs leading-relaxed uppercase text-neutral-600 mb-4">
          INFINITE LANDSCAPE GENERATION USING PERLIN NOISE.
        </p>
        <hr class="border-black mb-3" />
        <div class="flex gap-4 text-[10px] tracking-wider font-bold">
          <span>C++</span>
          <span>RAYLIB</span>
        </div>
      </div>

    </div>
  </section>

  <!-- CONTACT / INITIATE PROJECT -->
  <section id="contact" class="px-6 py-20 text-center">
    <h2 class="text-4xl md:text-6xl lg:text-7xl font-extrabold tracking-tight mb-12">
      INITIATE_PROJECT
    </h2>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="mailto:hello@toni.dev" class="border border-black px-6 py-3 hover:bg-black hover:text-white transition-colors">
        <span class="text-[10px] tracking-wider text-neutral-500 block mb-1">EMAIL_LINK</span>
        <span class="text-sm font-bold">SEND_MAIL</span>
      </a>
      <a href="#" class="border border-black px-6 py-3 hover:bg-black hover:text-white transition-colors">
        <span class="text-[10px] tracking-wider text-neutral-500 block mb-1">CALENDAR_SYNC</span>
        <span class="text-sm font-bold">BOOK_CALL</span>
      </a>
      <a href="#" class="border border-black px-6 py-3 hover:bg-black hover:text-white transition-colors">
        <span class="text-[10px] tracking-wider text-neutral-500 block mb-1">SOCIAL_AUTH</span>
        <span class="text-sm font-bold">LINKEDIN</span>
      </a>
    </div>
  </section>

</BaseLayout>
